{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "NodeNext",
    "noEmit": true,
    "esModuleInterop": true,
    "allowJs": true,
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"],
    "rootDir": "src",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/*.ts"],
  "exclude": ["node_modules", "__tests__"]
}
